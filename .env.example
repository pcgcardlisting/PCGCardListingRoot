# ─── Database ──────────────────────────────────────────────────────────────────
# Local development (SQLite file):
DATABASE_URL="file:./dev.db"
TURSO_AUTH_TOKEN=""

# Production (Turso cloud — https://turso.tech):
# DATABASE_URL="libsql://your-db-name-yourusername.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a secret: run `openssl rand -base64 32` or any 32+ char random string
AUTH_SECRET="your-auth-secret-change-this-in-production"

# Set to your production URL when deploying (e.g. https://pcgcardlisting.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/ → APIs & Services → Credentials
# Authorised redirect URI: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── TCGPlayer API (optional) ──────────────────────────────────────────────────
# Get from: https://developer.tcgplayer.com/
# App works without these — uses pokemon-tcg.io as fallback
TCGPLAYER_PUBLIC_KEY="your-tcgplayer-public-key"
TCGPLAYER_PRIVATE_KEY="your-tcgplayer-private-key"

# ─── eBay API (optional) ───────────────────────────────────────────────────────
# Get from: https://developer.ebay.com/
# App works without these — uses mock data as fallback
EBAY_CLIENT_ID="your-ebay-client-id"
EBAY_CLIENT_SECRET="your-ebay-client-secret"
EBAY_ENVIRONMENT="production"
